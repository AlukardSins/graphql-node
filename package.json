{
  "name": "graph",
  "version": "1.0.0",
  "main": "server.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "tsc && node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "author": "Daniel Rodriguez",
  "license": "MIT",
  "description": "A proof-of-concept Node.js GraphQL API for managing books and authors, using TypeScript, Express, and MongoDB. Includes Docker support and example queries.",
  "dependencies": {
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-graphql": "^0.12.0",
    "graphql": "^15.9.0",
    "mongoose": "^8.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/express": "^5.0.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.34.0"
  }
}
